<style>
/* ── SABnzbd Tile ────────────────────────────────────────── */
.sab-empty   { color:#777; font-style:italic; font-size:12px; }
/* Queue item */
.sab-qitem   { padding:2px 0 3px; }
.sab-qhd     { display:flex; justify-content:space-between; align-items:baseline; gap:6px; margin-bottom:3px; }
.sab-qname-w { flex:1; min-width:0; overflow:hidden; }
.sab-qname   { font-size:11px; font-weight:bold; color:#ddd; white-space:nowrap; display:block; }
.sab-qpct    { font-size:10px; color:#f4a11c; flex-shrink:0; white-space:nowrap; }
/* Progress bar */
.sab-prog-bg   { background:rgba(255,255,255,.15); border-radius:2px; height:5px; overflow:hidden; }
.sab-prog-fill { height:100%; background:#f4a11c; transition:width 1s linear; }
.sab-prog-fill.paused { background:#888; }
/* Scroll animation */
@keyframes sab-marquee {
    0%, 20%  { transform: translateX(0); }
    80%, 100% { transform: translateX(var(--sab-shift, 0px)); }
}
.sab-scroll { animation: sab-marquee 5s ease-in-out infinite; }
</style>
<script>
(function() {
    var POLL_MS = 10000;

    function esc(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;')
                        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function applyScroll(container) {
        setTimeout(function() {
            var els = container.querySelectorAll('.sab-qname');
            for (var i = 0; i < els.length; i++) {
                var el = els[i];
                var shift = el.scrollWidth - el.offsetWidth;
                if (shift > 4) {
                    el.style.setProperty('--sab-shift', '-' + shift + 'px');
                    el.classList.add('sab-scroll');
                } else {
                    el.classList.remove('sab-scroll');
                }
            }
        }, 100);
    }

    function render(data) {
        var statusEl = document.getElementById('sab-status');
        var speedEl  = document.getElementById('sab-speed');
        var etaEl    = document.getElementById('sab-eta');
        var bodyEl   = document.getElementById('sab-body');
        if (!statusEl || !bodyEl) return;

        var q = data.queue || [];

        if (data.paused) {
            statusEl.textContent = 'Paused';
            if (speedEl) speedEl.textContent = '';
            if (etaEl)   etaEl.textContent   = '';
        } else if (q.length > 0) {
            statusEl.textContent = 'Downloading';
            if (speedEl) speedEl.textContent = data.speed || '';
            if (etaEl)   etaEl.textContent   = data.eta ? 'ETA ' + data.eta : '';
        } else {
            statusEl.textContent = 'Idle';
            if (speedEl) speedEl.textContent = '';
            if (etaEl)   etaEl.textContent   = '';
        }

        var html = '';
        if (q.length > 0) {
            var item = q[0];
            var isPaused = (item.status || '').toLowerCase() === 'paused';
            html = '<div class="sab-qitem">'
                 +   '<div class="sab-qhd">'
                 +     '<div class="sab-qname-w"><div class="sab-qname">' + esc(item.name) + '</div></div>'
                 +     '<div class="sab-qpct">' + item.pct + '%</div>'
                 +   '</div>'
                 +   '<div class="sab-prog-bg">'
                 +     '<div class="sab-prog-fill' + (isPaused ? ' paused' : '') + '" style="width:' + item.pct + '%"></div>'
                 +   '</div>'
                 + '</div>';
        } else {
            html = '<span class="sab-empty">Queue empty</span>';
        }

        bodyEl.innerHTML = html;
        applyScroll(bodyEl);
    }

    function fetchData() {
        var xhr = new XMLHttpRequest();
        xhr.open('GET', '/plugins/sabnzbd-tile/ajax.php?_t=' + Date.now(), true);
        xhr.onload = function() {
            if (xhr.status === 200) {
                try {
                    var data = JSON.parse(xhr.responseText);
                    if (data && data.error) {
                        var el = document.getElementById('sab-status');
                        if (el) el.textContent = data.error === 'not_configured'
                            ? 'Not configured — visit Settings › SABnzbd'
                            : 'Error: ' + data.error;
                        var body = document.getElementById('sab-body');
                        if (body) body.innerHTML = '';
                    } else {
                        render(data);
                    }
                } catch(e) {}
            }
        };
        xhr.onerror = function() {
            var el = document.getElementById('sab-status');
            if (el) el.textContent = 'Connection error';
        };
        xhr.send();
    }

    if (window._sabInterval) clearInterval(window._sabInterval);
    window._sabInterval = setInterval(fetchData, POLL_MS);
    setTimeout(fetchData, 600);
})();
</script>
